@page "/builder"

<div class="builder-page">

    <!-- HOME BUTTON HIT AREA -->
    <button class="home-hit-area" @onclick="GoHome"></button>

    <!-- TOP NAV -->
    <div class="landing-nav-buttons">
        <button class="landing-btn" @onclick="ViewMenu">View Menu</button>
        <button class="landing-btn" @onclick="GoToDelivery">Order Delivery</button>
        <button class="landing-btn" @onclick="GoToPickup">Order Pickup</button>
    </div>

    <div class="landing-icons">
        <button class="icon-plain" @onclick="GoToProfile">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M12 12c2.8 0 5-2.2 5-5s-2.2-5-5-5-5 2.2-5 5 2.2 5 5 5zm0 2c-3.3 0-10 1.7-10 5v2h20v-2c0-3.3-6.7-5-10-5z"
                      fill="none" stroke="white" stroke-width="1.6" />
            </svg>
        </button>

        <button class="icon-plain" @onclick="OpenCart">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M3 4h2l2 12h11l2-8H8"
                      fill="none" stroke="white" stroke-width="1.6"
                      stroke-linecap="round" stroke-linejoin="round" />
                <circle cx="10" cy="19" r="1.4" fill="white" />
                <circle cx="17" cy="19" r="1.4" fill="white" />
            </svg>
        </button>
    </div>

    <!-- MAIN CONTENT -->
    <div class="builder-content">

        <!-- LEFT PANEL: BUILD YOUR PIZZA -->
        <div class="builder-panel">
            <h2 class="builder-title">Build Your Pizza</h2>

            <div class="builder-pizza-layout">
                <div class="pizza-image">
                    <img src="/Images/Pizza.png" alt="Pizza" />
                </div>

                <div class="pizza-options">
                    <div class="pizza-section">
                        <h3 class="section-title">Pizza Size :</h3>
                        <div class="option-list">
                            <label>
                                <input type="radio" name="pizza-size" @onchange='@(() => SelectedSize = "Byte")' />
                                Byte Sized (10”) – personal
                            </label>
                            <label>
                                <input type="radio" name="pizza-size" @onchange='@(() => SelectedSize = "Kilo")' />
                                KiloByte (12”) – medium
                            </label>
                            <label>
                                <input type="radio" name="pizza-size" @onchange='@(() => SelectedSize = "Mega")' />
                                MegaByte (14”) – large
                            </label>
                            <label>
                                <input type="radio" name="pizza-size" @onchange='@(() => SelectedSize = "Giga")' />
                                GigaByte (16”) – extra large
                            </label>
                            <label>
                                <input type="radio" name="pizza-size" @onchange='@(() => SelectedSize = "Tera")' />
                                TeraByte (18”) – party size
                            </label>
                        </div>
                    </div>

                    <div class="pizza-section">
                        <h3 class="section-title">Crust Type :</h3>
                        <div class="option-row">
                            <label>
                                <input type="radio" name="pizza-crust" @onchange='@(() => SelectedCrust = "Thin")' />
                                Thin Crust
                            </label>
                            <label>
                                <input type="radio" name="pizza-crust" @onchange='@(() => SelectedCrust = "HandTossed")' />
                                Hand-Tossed
                            </label>
                            <label>
                                <input type="radio" name="pizza-crust" @onchange='@(() => SelectedCrust = "DeepDish")' />
                                Deep Dish
                            </label>
                        </div>
                    </div>

                    <div class="pizza-section">
                        <h3 class="section-title">Pizza Sauce :</h3>
                        <div class="option-row">
                            <label>
                                <input type="radio" name="pizza-sauce" @onchange='@(() => SelectedSauce = "Red")' />
                                Marinara
                            </label>
                            <label>
                                <input type="radio" name="pizza-sauce" @onchange='@(() => SelectedSauce = "White")' />
                                BBQ
                            </label>
                            <label>
                                <input type="radio" name="pizza-sauce" @onchange='@(() => SelectedSauce = "Parmlic")' />
                                Pesto
                            </label>
                        </div>
                    </div>

                    <div class="pizza-section">
                        <h3 class="section-title">Choose up to 4 Toppings :</h3>

                        <!-- visual indicator -->
                        <div class="topping-counter">
                            @SelectedToppingCount / 4 selected
                            @if (SelectedToppingCount >= 4)
                            {
                                <span class="topping-warning">Max toppings reached</span>
                            }
                        </div>

                        <div class="toppings-grid">
                            @foreach (var topping in Toppings)
                            {
                                <label>
                                    <input type="checkbox"
                                           checked="@topping.Selected"
                                           disabled="@(!topping.Selected && SelectedToppingCount >=4)"
                                           @onchange="(e) => OnToppingChanged(topping, e)" />
                                    @topping.Name
                                </label>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pizza quantity + Add to cart -->
            <div class="builder-footer-row">
                <div class="quantity-controls">
                    <button class="qty-btn" @onclick="DecreasePizzaQty">−</button>
                    <span class="qty-value">@PizzaQuantity</span>
                    <button class="qty-btn" @onclick="IncreasePizzaQty">+</button>
                </div>
                <div class="panel-total">
                    Pizza Total : <span class="money">@PizzaTotal.ToString("C")</span>
                </div>
                <button class="panel-cta" @onclick="AddPizzaToCart">ADD TO CART</button>
            </div>
        </div>

        <!-- RIGHT PANEL: DRINKS & SIDES -->
        <div class="builder-panel">
            <h2 class="builder-title">Add Drinks &amp; Sides</h2>

            <div class="drinks-sides-section">
                <h3 class="section-title">Drinks</h3>

                @foreach (var item in DrinkItems)
                {
                    <div class="line-item">
                        <span class="item-name">@item.Name</span>
                        <div class="item-controls">
                            <select class="drink-size" @bind="item.Size">
                                <option value="Small">Small</option>
                                <option value="Medium">Medium</option>
                                <option value="Large">Large</option>
                            </select>

                            <div class="quantity-controls">
                                <button class="qty-btn" @onclick="() => DecreaseItem(item)">−</button>
                                <span class="qty-value">@item.Quantity</span>
                                <button class="qty-btn" @onclick="() => IncreaseItem(item)">+</button>
                            </div>
                        </div>
                    </div>
                }

                <h3 class="section-title section-sides">Sides</h3>

                @foreach (var item in SideItems)
                {
                    <div class="line-item">
                        <span class="item-name">@item.Name</span>
                        <div class="item-controls">
                            <div class="quantity-controls">
                                <button class="qty-btn" @onclick="() => DecreaseItem(item)">−</button>
                                <span class="qty-value">@item.Quantity</span>
                                <button class="qty-btn" @onclick="() => IncreaseItem(item)">+</button>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="builder-footer-row builder-footer-right">
                <div class="panel-total">
                    Order Total : <span class="money">@OrderTotal.ToString("C")</span>
                </div>
                <button class="panel-cta" @onclick="OpenCart">VIEW CART</button>
            </div>
        </div>

    </div>

    <!-- CART SLIDE-OUT -->
    @if (ShowCart)
    {
        <div class="cart-overlay">
            <div class="cart-panel">
                <div class="cart-header">
                    <span class="cart-title">Your Order</span>
                    <button class="cart-close" @onclick="CloseCart">Close</button>
                </div>

                <div class="cart-items">
                    @if (OrderTotal == 0)
                    {
                        <p>Your cart is empty.</p>
                    }
                    else
                    {
                        <p>Pizza Total: @PizzaTotal.ToString("C")</p>
                        <p>Drinks &amp; Sides: @SideTotal.ToString("C")</p>
                    }
                </div>

                @if (OrderTotal > 0)
                {
                    <div class="cart-summary">
                        <div class="cart-line">
                            <span>Subtotal</span>
                            <span>@OrderTotal.ToString("C")</span>
                        </div>
                        <hr />
                        <div class="cart-total">
                            <span>Total</span>
                            <span>@OrderTotal.ToString("C")</span>
                        </div>
                    </div>
                    <button class="checkout-btn" @onclick="GoToCheckout">CHECK OUT</button>
                }
            </div>
        </div>
    }

</div>

@code {
    [Inject] NavigationManager Nav { get; set; }

    // NAVIGATION
    void GoHome()       => Nav.NavigateTo("/");
    void ViewMenu()     => Nav.NavigateTo("/menu");
    void GoToDelivery() => Nav.NavigateTo("/builder?mode=delivery");
    void GoToPickup()   => Nav.NavigateTo("/builder?mode=pickup");
    void GoToProfile()  => Nav.NavigateTo("/profile");

    // CART
    bool ShowCart = false;
    void OpenCart() => ShowCart = true;
    void CloseCart() => ShowCart = false;

    // ---------- PIZZA TOP ----------
    string SelectedSize  { get; set; } = "Mega";
    string SelectedCrust { get; set; } = "Thin";
    string SelectedSauce { get; set; } = "Marinara";

    // ----- TOPPINGS (max 4, all free) -----
    class ToppingOption
    {
        public string Name { get; set; } = "";
        public bool Selected { get; set; }
    }

    List<ToppingOption> Toppings = new()
    {
        new ToppingOption { Name = "Provolone" },
        new ToppingOption { Name = "Mozzarella" },
        new ToppingOption { Name = "Parmesan Blend" },
        new ToppingOption { Name = "Pepperoni" },

        new ToppingOption { Name = "Bacon" },
        new ToppingOption { Name = "Steak" },
        new ToppingOption { Name = "Chicken" },
        new ToppingOption { Name = "Banana Peppers" },

        new ToppingOption { Name = "Sausage" },
        new ToppingOption { Name = "Onions" },
        new ToppingOption { Name = "Mushrooms" },
        new ToppingOption { Name = "Black Olives" },

        new ToppingOption { Name = "Spinach" },
        new ToppingOption { Name = "Pineapple" }
    };

    int SelectedToppingCount => Toppings.Count(t => t.Selected);

    int GetToppingCount() => SelectedToppingCount;

    void OnToppingChanged(ToppingOption topping, ChangeEventArgs e)
    {
        bool newValue = e.Value is bool b && b;

        // If user unchecks – always allow it
        if (!newValue)
        {
            topping.Selected = false;
            return;
        }

        // If already at 4, don't allow adding another
        const int toppingMax = 4;
        if (SelectedToppingCount >= toppingMax)
        {
            topping.Selected = false;
            StateHasChanged();
            return;
        }

        topping.Selected = true;
    }

    // start at 0 so cart is empty
    int PizzaQuantity { get; set; } = 0;

    decimal GetBasePrice() => SelectedSize switch
    {
        "Byte" => 9.99m,
        "Kilo" => 12.99m,
        "Mega" => 14.99m,
        "Giga" => 16.99m,
        "Tera" => 19.99m,
        _ => 14.99m
    };

    // free toppings
    decimal PizzaTotal => PizzaQuantity * GetBasePrice();

    void IncreasePizzaQty() => PizzaQuantity++;
    void DecreasePizzaQty()
    {
        if (PizzaQuantity > 0) PizzaQuantity--;
    }

    void AddPizzaToCart()
    {
        if (PizzaQuantity == 0)
        {
            PizzaQuantity = 1;
        }

        OpenCart();
    }

    // ---------- DRINKS & SIDES ----------
    class OrderItem
    {
        public string Name { get; set; } = "";
        public decimal BasePrice { get; set; }
        public int Quantity { get; set; }
        public bool HasSizes { get; set; } = false;
        public string Size { get; set; } = "Medium";
    }

    // 5 drinks, each with size
    List<OrderItem> DrinkItems = new()
    {
        new OrderItem { Name = "Sprite",   BasePrice = 1.99m, HasSizes = true },
        new OrderItem { Name = "Coke",     BasePrice = 1.99m, HasSizes = true },
        new OrderItem { Name = "Water",    BasePrice = 1.49m, HasSizes = true },
        new OrderItem { Name = "Lemonade", BasePrice = 1.99m, HasSizes = true },
        new OrderItem { Name = "Iced Tea", BasePrice = 1.99m, HasSizes = true }
    };

    // sides
    List<OrderItem> SideItems = new()
    {
        new OrderItem { Name = "Garlic Breadsticks", BasePrice = 5.99m },
        new OrderItem { Name = "Cheesy Bread",       BasePrice = 6.49m },
        new OrderItem { Name = "Side Salad",         BasePrice = 4.99m },
        new OrderItem { Name = "Wings (8)",          BasePrice = 9.99m }
    };

    decimal GetItemPrice(OrderItem item)
    {
        if (!item.HasSizes) return item.BasePrice;

        return item.Size switch
        {
            "Small"  => item.BasePrice,
            "Medium" => item.BasePrice + 0.50m,
            "Large"  => item.BasePrice + 1.00m,
            _        => item.BasePrice
        };
    }

    void IncreaseItem(OrderItem item) => item.Quantity++;
    void DecreaseItem(OrderItem item)
    {
        if (item.Quantity > 0) item.Quantity--;
    }

    decimal SideTotal =>
        DrinkItems.Sum(i => GetItemPrice(i) * i.Quantity) +
        SideItems.Sum(i => GetItemPrice(i) * i.Quantity);

    decimal OrderTotal => PizzaTotal + SideTotal;

    void GoToCheckout() => Nav.NavigateTo("/checkout");
}

