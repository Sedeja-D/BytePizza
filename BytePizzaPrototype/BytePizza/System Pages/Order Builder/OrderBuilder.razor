@page "/builder"
@using BytePizza.Services.Interfaces
@using BytePizza.Models
@using BytePizza.Services

<div class="builder-page">

    <!-- HOME BUTTON HIT AREA -->
    <button class="home-hit-area" @onclick="GoHome"></button>

    <!-- TOP NAV -->
    <div class="landing-nav-buttons">
        <button class="landing-btn" @onclick="ViewMenu">View Menu</button>
        <button class="landing-btn" @onclick="GoToDelivery">Order Delivery</button>
        <button class="landing-btn" @onclick="GoToPickup">Order Pickup</button>
    </div>

    <div class="landing-icons">
        <button class="icon-plain" @onclick="OpenProfile">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M12 12c2.8 0 5-2.2 5-5s-2.2-5-5-5-5 2.2-5 5 2.2 5 5 5zm0 2c-3.3 0-10 1.7-10 5v2h20v-2c0-3.3-6.7-5-10-5z"
                      fill="none" stroke="white" stroke-width="1.6" />
            </svg>
        </button>

        <button class="icon-plain" @onclick="OpenCart">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M3 4h2l2 12h11l2-8H8"
                      fill="none" stroke="white" stroke-width="1.6"
                      stroke-linecap="round" stroke-linejoin="round" />
                <circle cx="10" cy="19" r="1.4" fill="white" />
                <circle cx="17" cy="19" r="1.4" fill="white" />
            </svg>
        </button>
    </div>

    <!-- LOADING STATE -->
    @if (IsLoading)
    {
        <div style="text-align: center; padding: 60px; color: white;">
            <p>Loading menu...</p>
        </div>
    }
    else
    {
        <!-- MAIN CONTENT -->
        <div class="builder-content">

            <!-- LEFT PANEL: BUILD YOUR PIZZA -->
            <div class="builder-panel">
                <h2 class="builder-title">Build Your Pizza</h2>

                <div class="builder-pizza-layout">
                    <div class="pizza-image">
                        <img src="/Images/Pizza.png" alt="Pizza" />
                    </div>

                    <div class="pizza-options">
                        <div class="pizza-section">
                            <h3 class="section-title">Pizza Size :</h3>
                            <div class="option-list">
                                @foreach (var size in PizzaSizes)
                                {
                                    <label>
                                        <input type="radio"
                                               name="pizza-size"
                                               checked="@(SelectedSize == size.Name)"
                                               @onchange="@(() => SelectedSize = size.Name)" />
                                        @size.Name - @size.Price.ToString("C")
                                    </label>
                                }
                            </div>
                        </div>

                        <div class="pizza-section">
                            <h3 class="section-title">Crust Type :</h3>
                            <div class="option-row">
                                @foreach (var crust in Crusts)
                                {
                                    <label>
                                        <input type="radio"
                                               name="pizza-crust"
                                               checked="@(SelectedCrust == crust.Name)"
                                               @onchange="@(() => SelectedCrust = crust.Name)" />
                                        @crust.Name
                                        @if (crust.Price > 0)
                                        {
                                            <text> (+@crust.Price.ToString("C"))</text>
                                        }
                                    </label>
                                }
                            </div>
                        </div>

                        <div class="pizza-section">
                            <h3 class="section-title">Pizza Sauce :</h3>
                            <div class="option-row">
                                @foreach (var sauce in Sauces)
                                {
                                    <label>
                                        <input type="radio"
                                               name="pizza-sauce"
                                               checked="@(SelectedSauce == sauce.Name)"
                                               @onchange="@(() => SelectedSauce = sauce.Name)" />
                                        @sauce.Name
                                        @if (sauce.Price > 0)
                                        {
                                            <text> (+@sauce.Price.ToString("C"))</text>
                                        }
                                    </label>
                                }
                            </div>
                        </div>

                        <div class="pizza-section">
                            <h3 class="section-title">Choose up to 4 Toppings :</h3>

                            <!-- visual indicator -->
                            <div class="topping-counter">
                                @SelectedToppingCount / 4 selected
                                @if (SelectedToppingCount >= 4)
                                {
                                    <span class="topping-warning">Max toppings reached</span>
                                }
                            </div>

                            <div class="toppings-grid">
                                @foreach (var topping in Toppings)
                                {
                                    <label>
                                        <input type="checkbox"
                                               checked="@topping.Selected"
                                               disabled="@(!topping.Selected && SelectedToppingCount >= 4)"
                                               @onchange="(e) => OnToppingChanged(topping, e)" />
                                        @topping.Name (+@topping.Price.ToString("C"))
                                    </label>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Pizza quantity + Add to cart -->
                <div class="builder-footer-row">
                    <div class="quantity-controls">
                        <button class="qty-btn" @onclick="DecreasePizzaQty">−</button>
                        <span class="qty-value">@PizzaQuantity</span>
                        <button class="qty-btn" @onclick="IncreasePizzaQty">+</button>
                    </div>
                    <div class="panel-total">
                        Pizza Total : <span class="money">@PizzaTotal.ToString("C")</span>
                    </div>
                    <button class="panel-cta" @onclick="AddPizzaToCart">ADD TO CART</button>
                </div>
            </div>

            <!-- RIGHT PANEL: DRINKS & SIDES -->
            <div class="builder-panel">
                <h2 class="builder-title">Add Drinks &amp; Sides</h2>

                <div class="drinks-sides-section">
                    <h3 class="section-title">Drinks</h3>

                    @foreach (var drink in Drinks)
                    {
                        <div class="line-item">
                            <span class="item-name">@drink.Name</span>
                            <div class="item-controls">
                                <select class="drink-size" @bind="drink.SelectedSize" @bind:after="StateHasChanged">
                                    @foreach (var size in DrinkSizes)
                                    {
                                        <option value="@size.Name">@size.Name - @size.Price.ToString("C")</option>
                                    }
                                </select>

                                <div class="quantity-controls">
                                    <button class="qty-btn" @onclick="() => DecreaseItem(drink)">−</button>
                                    <span class="qty-value">@drink.Quantity</span>
                                    <button class="qty-btn" @onclick="() => IncreaseItem(drink)">+</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="builder-footer-row builder-footer-right">
                    <div class="panel-total">
                        Order Total : <span class="money">@OrderTotal.ToString("C")</span>
                    </div>
                    <button class="panel-cta" @onclick="OpenCart">VIEW CART</button>
                </div>
            </div>

        </div>
    }

    <!-- CART SLIDE-OUT -->
    @if (ShowCart)
    {
        <div class="cart-overlay">
            <div class="cart-panel">
                <div class="cart-header">
                    <span class="cart-title">Your Order</span>
                    <button class="cart-close" @onclick="CloseCart">Close</button>
                </div>

                <div class="cart-items">
                    @if (OrderTotal == 0)
                    {
                        <p>Your cart is empty.</p>
                    }
                    else
                    {
                        <p>Pizza Total: @PizzaTotal.ToString("C")</p>
                        <p>Drinks: @DrinkTotal.ToString("C")</p>
                    }
                </div>

                @if (OrderTotal > 0)
                {
                    <div class="cart-summary">
                        <div class="cart-line">
                            <span>Subtotal</span>
                            <span>@OrderTotal.ToString("C")</span>
                        </div>
                        <hr />
                        <div class="cart-total">
                            <span>Total</span>
                            <span>@OrderTotal.ToString("C")</span>
                        </div>
                    </div>
                    <button class="checkout-btn" @onclick="GoToCheckout">CHECK OUT</button>
                }
            </div>
        </div>
    }

    <!-- Profile slideout - borrows from ShowCart to allow user to logout/ view profile info -->
    @if (ShowProfile)
    {
        <div class="cart-overlay">
            <div class="cart-panel">
                <div class="cart-header">
                    <span class="cart-title">Your Profile</span>
                    <button class="cart-close" @onclick="CloseProfile">Close</button>
                </div>

                <div class="cart-items">
                    @if (CurrentCustomer != null)
                    {
                        <p>Welcome, @(CurrentCustomer?.Name ?? "Guest")!</p>
                        <p>Phone: @(CurrentCustomer?.Phone ?? "")</p>
                        <p>Address: @(CurrentCustomer?.Address ?? "")</p>
                    }
                </div>
                @if (CurrentCustomer != null)
                {
                <button class="checkout-btn" @onclick="LogOut">LOG OUT</button>
                }
            </div>
        </div>
    }

</div>

@code {
    // injection   
    [Inject] NavigationManager Nav { get; set; } = default!;
    [Inject] IMenuService MenuService { get; set; } = default!;
    [Inject] CartService CartService { get; set; } = default!;


    //  ui 
    bool IsLoading = true;

    bool ShowCart = false;

    //  navigation  
    void GoHome() => Nav.NavigateTo("/");

    void ViewMenu() => Nav.NavigateTo("/menu");

    // delivery to order page
    void GoToDelivery() => Nav.NavigateTo("/builder?mode=delivery");

    // pickup order page 
    void GoToPickup() => Nav.NavigateTo("/builder?mode=pickup");

    // user profile page 
    void GoToProfile() => Nav.NavigateTo("/profile");

    //  cart 
    void OpenCart() => ShowCart = true;

    void CloseCart() => ShowCart = false;

    // ---------- PIZZA TOP ----------
    string SelectedSize  { get; set; } = "Mega";
    string SelectedCrust { get; set; } = "Thin";
    string SelectedSauce { get; set; } = "Marinara";

    //  toppings 
    class ToppingOption
    {
        public string Name { get; set; } = "";
        public decimal Price { get; set; }
        public bool Selected { get; set; }
    }

    List<ToppingOption> Toppings = new();

    int SelectedToppingCount => Toppings.Count(t => t.Selected);
    //selecting of toppings 
    void OnToppingChanged(ToppingOption topping, ChangeEventArgs e)
    {
        bool newValue = e.Value is bool b && b;

        //unchecking any topping
        if (!newValue)
        {
            topping.Selected = false;
            return;
        }

        // 4 toppings 
        const int toppingMax = 4;
        if (SelectedToppingCount >= toppingMax)
        {
            topping.Selected = false;
            StateHasChanged();
            return;
        }

        topping.Selected = true;
    }

    //pizza quanitry and the price of size, crust, sauce and toppings 
    int PizzaQuantity { get; set; } = 0;

    decimal GetBasePrice()
    {
        var size = PizzaSizes.FirstOrDefault(s => s.Name == SelectedSize);
        return size.Price;
    }

    decimal GetCrustPrice()
    {
        var crust = Crusts.FirstOrDefault(c => c.Name == SelectedCrust);
        return crust.Price;
    }

    decimal GetSaucePrice()
    {
        var sauce = Sauces.FirstOrDefault(s => s.Name == SelectedSauce);
        return sauce.Price;
    }

    decimal GetToppingsCost()
    {
        return Toppings.Where(t => t.Selected).Sum(t => t.Price);
    }

    //total cost of that pizza 
    decimal PizzaTotal => PizzaQuantity * (GetBasePrice() + GetCrustPrice() + GetSaucePrice() + GetToppingsCost());


    // pizza quanity 
    void IncreasePizzaQty() => PizzaQuantity++;

    void DecreasePizzaQty()
    {
        if (PizzaQuantity > 0) PizzaQuantity--;
    }

    //add pizza to cart 
    void AddPizzaToCart()
    {
        if (PizzaQuantity == 0)
        {
            PizzaQuantity = 1;
        }
        OpenCart();
    }

    // drinks  
    //get the drinks, sizes and quanitys 
    class DrinkItem
    {
        public string Name { get; set; } = "";
        public string SelectedSize { get; set; } = "";
        public int Quantity { get; set; } = 0;
    }

    List<DrinkItem> Drinks = new();

    //get and return the price of the drink for that size 
    decimal GetDrinkPrice(DrinkItem drink)
    {
        var size = DrinkSizes.FirstOrDefault(s => s.Name == drink.SelectedSize);
        return size.Price;
    }

    //drinks quanity increase and decrease 
    void IncreaseItem(DrinkItem item) => item.Quantity++;

    void DecreaseItem(DrinkItem item)
    {
        if (item.Quantity > 0) item.Quantity--;
    }

    //get the total price for that drink
    decimal DrinkTotal => Drinks.Sum(d => GetDrinkPrice(d) * d.Quantity);

    //overall total for drinks and the pizza 
    decimal OrderTotal => PizzaTotal + DrinkTotal;

    //Checkout 
    void GoToCheckout()
    {
        // has to be something in the order 
        if (OrderTotal == 0)
        {
            return; 
        }

        // Store cart data in CartService
        CartService.PizzaSize = SelectedSize;
        CartService.PizzaCrust = SelectedCrust;
        CartService.PizzaSauce = SelectedSauce;
        CartService.PizzaToppings = Toppings.Where(t => t.Selected).Select(t => t.Name).ToList();
        CartService.PizzaQuantity = PizzaQuantity;
        CartService.PizzaPrice = PizzaTotal;

        // Store drinks
        CartService.Drinks = Drinks
            .Where(d => d.Quantity > 0)
            .Select(d => new CartService.CartDrink
            {
                Name = d.Name,
                Size = d.SelectedSize,
                Quantity = d.Quantity,
                Price = GetDrinkPrice(d)
            })
            .ToList();

        // Navigate to checkout
        Nav.NavigateTo("/checkout");
    }

  
    protected override async Task OnInitializedAsync()
    {
        try
        {
            //get menu data from menu services 
            PizzaSizes = await MenuService.GetPizzaSizesAsync();
            Crusts = await MenuService.GetPizzaCrustsAsync();
            Sauces = await MenuService.GetSaucesAsync();
            var toppingsData = await MenuService.GetToppingsAsync();
            var drinksData = await MenuService.GetDrinksAsync();
            DrinkSizes = await MenuService.GetDrinkSizesAsync();

            // Set pizza default 
            if (PizzaSizes.Any())
            {
                SelectedSize = PizzaSizes[0].Name;
            }

            if (Crusts.Any())
            {
                SelectedCrust = Crusts[0].Name;
            }

            if (Sauces.Any())
            {
                SelectedSauce = Sauces[0].Name;
            }

            // database toppings to ui toppings selection screen 
            Toppings = toppingsData.Select(t => new ToppingOption
            {
                Name = t.Name,
                Price = t.Price,
                Selected = false
            }).ToList();
            //drink items from menu services 
            Drinks = drinksData.Select(d => new DrinkItem
            {
                Name = d.Name,
                SelectedSize = DrinkSizes.Any() ? DrinkSizes[0].Name : "",
                Quantity = 0
            }).ToList();
            //validate that the menu loaded correctly 
            IsLoading = false;
        }
        catch (Exception ex)
        {
            //Error if something with menu loading goes wrong 
            Console.WriteLine($"Error loading menu: {ex.Message}");
            IsLoading = false;
        }
    }
}