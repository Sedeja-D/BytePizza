@page "/checkout"
@using BytePizza.Services.Interfaces
@using BytePizza.Models
@using BytePizza.Services

<div class="checkout-page">

    <!-- HOME BUTTON HIT AREA -->
    <button class="home-hit-area" @onclick="GoHome"></button>

    <div class="checkout-shell">
        <!-- LEFT SIDE: ORDER SUMMARY -->
        <section class="checkout-left">
            <h1 class="checkout-heading">Your Order</h1>

            @if (!CartService.HasItems())
            {
                <p class="checkout-empty">Your cart is empty.</p>
            }
            else
            {
                <!-- Pizza -->
                @if (CartService.PizzaQuantity > 0)
                {
                    <div class="checkout-item">
                        <div class="checkout-item-info">
                            <div class="checkout-item-name">
                                @CartService.PizzaPrice.ToString("C")
                            </div>
                            <div class="checkout-item-desc">
                                @CartService.PizzaCrust, @CartService.PizzaSauce Sauce
                                @if (CartService.PizzaToppings.Any())
                                {
                                    <br />
                                    <text>Toppings: @string.Join(", ", CartService.PizzaToppings)</text>
                                }
                            </div>
                        </div>

                        <div class="checkout-item-qty">
                            <span>Qty: @CartService.PizzaQuantity</span>
                        </div>
                    </div>
                }

                <!-- Drinks -->
                @foreach (var drink in CartService.Drinks.Where(d => d.Quantity > 0))
                {
                    <div class="checkout-item">
                        <div class="checkout-item-info">
                            <div class="checkout-item-name">
                                @drink.Name (@drink.Size)
                            </div>
                        </div>

                        <div class="checkout-item-qty">
                            <span>@drink.Quantity x @drink.Price.ToString("C")</span>
                        </div>
                    </div>
                }

                <hr class="checkout-separator" />

                <div class="checkout-totals">
                    <div class="checkout-line">
                        <span>Subtotal</span>
                        <span>@Subtotal.ToString("C")</span>
                    </div>
                    <div class="checkout-line">
                        <span>Tax (8%)</span>
                        <span>@Tax.ToString("C")</span>
                    </div>
                    <div class="checkout-line checkout-line-total">
                        <span>Total</span>
                        <span>@Total.ToString("C")</span>
                    </div>
                </div>
            }
        </section>

        <!-- RIGHT SIDE: CHECKOUT FORM -->
        <section class="checkout-right">
            <!-- logo centered -->
            <div class="checkout-logo-row">
                <img src="/Images/Logo.png"
                     alt="Byte Pizza"
                     class="checkout-logo-img" />
                <button class="checkout-close" @onclick="GoBackToBuilder">Close</button>
            </div>

            <div class="checkout-card">
                <!-- PICKUP / DELIVERY TOGGLE -->
                <div class="checkout-toggle">
                    <button class="toggle-btn @(CheckoutMode == "Pickup" ? "active" : "")"
                            @onclick='() => CheckoutMode = "Pickup"'>
                        PICKUP
                    </button>
                    <button class="toggle-btn @(CheckoutMode == "Delivery" ? "active" : "")"
                            @onclick='() => CheckoutMode = "Delivery"'>
                        DELIVERY
                    </button>
                </div>

                <!-- ADDRESS / NOTES -->
                <div class="checkout-section">
                    <label class="checkout-label">
                        @(CheckoutMode == "Delivery" ? "Delivery Address" : "Pickup Name")
                    </label>
                    <input class="checkout-input"
                           @bind="CheckoutAddress"
                           placeholder="123 Sesame Street" />

                    <label class="checkout-label">
                        @(CheckoutMode == "Delivery"
                                                ? "Delivery Notes (Optional)"
                                                : "Pickup Notes (Optional)")
                    </label>
                    <input class="checkout-input"
                           @bind="CheckoutNotes"
                           placeholder="Leave at door" />
                </div>

                <!-- SAVED CARDS -->
                <div class="checkout-section">
                    <div class="saved-cards-title">Saved Cards</div>
                    <div class="saved-cards-row">
                        <div class="saved-card @(SelectedCard == "visa" ? "selected" : "")"
                             @onclick='() => SelectedCard = "visa"'>
                            <div class="saved-card-brand">Visa ending 4567</div>
                            <div class="saved-card-meta">Exp 12/25</div>
                        </div>

                        <div class="saved-card @(SelectedCard == "mc" ? "selected" : "")"
                             @onclick='() => SelectedCard = "mc"'>
                            <div class="saved-card-brand">Mastercard #901</div>
                            <div class="saved-card-meta">Exp 07/24</div>
                        </div>

                        <div class="saved-card add-card @(SelectedCard == "new" ? "selected" : "")"
                             @onclick='() => SelectedCard = "new"'>
                            + ADD NEW CARD
                        </div>
                    </div>
                </div>

                <!-- PLACE ORDER -->
                <button class="place-order-btn"
                        @onclick="PlaceOrder"
                        disabled="@IsPlacingOrder">
                    @(IsPlacingOrder ? "PROCESSING..." : "PLACE ORDER")
                </button>

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="payment-error">
                        @ErrorMessage
                    </div>
                }
            </div>
        </section>
    </div>
</div>

@if (ShowConfirmation && CreatedOrder != null)
{
    <div class="confirm-overlay">
        <div class="confirm-shell">

            <!-- patterned side -->
            <div class="confirm-side"></div>

            <!-- middle white receipt card -->
            <div class="confirm-receipt">
                <button class="confirm-close" @onclick="CloseConfirmation">Close</button>

                <!-- logo -->
                <div class="confirm-logo-row">
                    <img src="/Images/Logo.png" alt="Byte Pizza" class="confirm-logo" />
                </div>

                <h1 class="confirm-title">Order Confirmed</h1>
                <p class="confirm-order-number">Order Number @CreatedOrder.OrderId</p>

                <hr class="confirm-divider" />

                <!-- delivery / pickup + time -->
                <div class="confirm-section">
                    <div class="confirm-label">
                        @CreatedOrder.OrderType
                    </div>
                    <div class="confirm-subtext">
                        @CreatedOrder.Orderdate.ToString("MMM d, yyyy 'at' h:mm tt")
                    </div>
                </div>

                <!-- Pizza -->
                @if (CreatedOrder.Pizza != null)
                {
                    <div class="confirm-item-block">
                        <div class="confirm-item-title">
                            @CreatedOrder.Pizza.PizzaSize Pizza - @CreatedOrder.Pizza.PizzaOrderPrice.ToString("C")
                        </div>
                        <div class="confirm-item-subtitle">
                            @CreatedOrder.Pizza.Crust, @CreatedOrder.Pizza.Sauce,
                            @CreatedOrder.Pizza.Toppings
                        </div>
                    </div>
                }

                <!-- Drinks -->
                @if (CreatedOrder.Drinks != null && CreatedOrder.Drinks.Any())
                {
                    @foreach (var drink in CreatedOrder.Drinks)
                    {
                        <div class="confirm-item-block">
                            <div class="confirm-item-title">
                                @drink.DrinkType (@drink.DrinkSize) - @drink.DrinkOrderPrice.ToString("C")
                            </div>
                            <div class="confirm-item-subtitle">
                                Quantity: @drink.DrinkQuantity
                            </div>
                        </div>
                    }
                }

                <hr class="confirm-divider" />

                <!-- totals -->
                <div class="confirm-totals">
                    <div class="confirm-line">
                        <span>Subtotal</span>
                        <span>@CreatedOrder.Subtotal.ToString("C")</span>
                    </div>
                    <div class="confirm-line">
                        <span>Tax</span>
                        <span>@CreatedOrder.Tax.ToString("C")</span>
                    </div>

                    <div class="confirm-total-line">
                        <span>Total</span>
                        <span>@CreatedOrder.Total.ToString("C")</span>
                    </div>

                    <div class="confirm-card-line">
                        **** **** **** 9012
                    </div>
                </div>

                <div class="confirm-thankyou">
                    Thank You !
                </div>
            </div>

            <!-- patterned side -->
            <div class="confirm-side"></div>
        </div>
    </div>
}


@code {
    //   INJECTION 
    [Inject] NavigationManager Nav { get; set; } = default!;
    [Inject] CartService CartService { get; set; } = default!;
    [Inject] IOrderService OrderService { get; set; } = default!;
    [Inject] ICustomerService CustomerService { get; set; } = default!;

    //  NAVIGATION 
    void GoHome() => Nav.NavigateTo("/");
    void GoBackToBuilder() => Nav.NavigateTo("/builder");

    //  CHECKOUT  
    decimal Subtotal => CartService.GetSubtotal();
    decimal Tax => Math.Round(Subtotal * 0.08m, 2);
    decimal Total => Subtotal + Tax;

    string CheckoutMode = "Pickup";
    string CheckoutAddress = "";
    string CheckoutNotes = "";
    string SelectedCard = "visa";

    bool IsPlacingOrder = false;
    string ErrorMessage = "";

    //  CONFIRMATION  
    bool ShowConfirmation = false;
    Order? CreatedOrder = null;

    //  PLACE ORDER 
    /// Creates order in database and shows confirmation
    async Task PlaceOrder()
    {
        if (string.IsNullOrWhiteSpace(SelectedCard))
        {
            ErrorMessage = "Please select a payment method";
            return;
        }

        if (!CartService.HasItems())
        {
            ErrorMessage = "Your cart is empty";
            return;
        }

        IsPlacingOrder = true;
        ErrorMessage = "";

        try
        {
            // customer log in 
            var customer = await CustomerService.GetCustomerAsync();
            if (customer == null)
            {
                ErrorMessage = "Please log in to place an order";
                Nav.NavigateTo("/login");
                return;
            }

            //pizza order object created 
            var pizzaOrder = new PizzaOrder
            {
                PizzaSize = CartService.PizzaSize,
                Crust = CartService.PizzaCrust,
                Sauce = CartService.PizzaSauce,
                Toppings = string.Join(",", CartService.PizzaToppings),
                Quantity = CartService.PizzaQuantity,
                PizzaOrderPrice = CartService.PizzaPrice
            };

            // Drink order list 
            var drinkOrders = CartService.Drinks
                .Select(d => new DrinkOrder
                {
                    DrinkType = d.Name,
                    DrinkSize = d.Size,
                    DrinkQuantity = d.Quantity,
                    DrinkOrderPrice = d.Price
                })
                .ToList();

            // create a new order in the database 
            CreatedOrder = await OrderService.CreateOrderAsync(
                customer.CustomerId,
                CheckoutMode,
                pizzaOrder,
                drinkOrders,
                taxRate: 0.08m
            );

            // remove everything in cart 
            CartService.Clear();

            // confirmation
            ShowConfirmation = true;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error placing order: {ex.Message}";
            Console.WriteLine($"Order error: {ex}");
        }
        finally
        {
            IsPlacingOrder = false;
        }
    }

    void CloseConfirmation()
    {
        ShowConfirmation = false;
        CreatedOrder = null;
        Nav.NavigateTo("/");
    }

    
    protected override void OnInitialized()
    {
        if (!CartService.HasItems())
        {
            Nav.NavigateTo("/builder");
        }
    }
}