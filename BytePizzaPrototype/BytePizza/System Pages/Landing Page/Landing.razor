@page "/"
@inject ICustomerService CustomerService

<div class="landing-page">

    <button class="home-hit-area" @onclick="GoHome"></button>

    <!-- Main nav buttons -->
    <div class="landing-nav-buttons">
        <button class="landing-btn" @onclick="StartViewMenu">View Menu</button>
        <button class="landing-btn" @onclick="StartDelivery">Order Delivery</button>
        <button class="landing-btn" @onclick="StartPickup">Order Pickup</button>
    </div>

    <!-- Big ORDER NOW button -->
    <div class="landing-main-cta">
        <button class="landing-cta-btn" @onclick="StartPickup">ORDER NOW</button>
    </div>

    <!-- Nav icons -->
    <div class="landing-icons">
        <!-- Profile -->
        <!-- Inactive for MVP <button class="icon-plain" onclick="GoToProfile"> -->
        <button class="icon-plain" type="button" @onclick="OpenProfile">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M12 12c2.8 0 5-2.2 5-5s-2.2-5-5-5-5 2.2-5 5 2.2 5 5 5zm0 2c-3.3 0-10 1.7-10 5v2h20v-2c0-3.3-6.7-5-10-5z"
                      fill="none" stroke="white" stroke-width="1.6" />
            </svg>
        </button>

        <!-- Cart -->
        <button class="icon-plain" @onclick="OpenCart">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M3 4h2l2 12h11l2-8H8" 
                      fill="none" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                <circle cx="10" cy="19" r="1.4" fill="white" />
                <circle cx="17" cy="19" r="1.4" fill="white" />
            </svg>
        </button>
    </div>
    
    <!-- LOGIN POPUP -->
    @if (ShowLogin)
    {
        <div class="login-overlay">
            <div class="login-box">

                <!-- Close Button -->
                <button class="close-btn" @onclick="CloseLogin">✕</button>

                <h1 class="login-title">Login</h1>

                @if (ShowError)
                {
                    <div class="error-text">Invalid number or password</div>
                }

                <!-- Inputs/icons -->
                <div class="input-group">
                    <span class="input-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="white" viewBox="0 0 24 24">
                            <path d="M12 12c2.7 0 5-2.3 5-5s-2.3-5-5-5-5 2.3-5 5 2.3 5 5 5zm0 2c-3.3 0-10 1.7-10 5v3h20v-3c0-3.3-6.7-5-10-5z"/>
                        </svg>
                    </span>
                    <input @bind="Phone" placeholder="Phone Number" />
                </div>

                <div class="input-group">
                    <span class="input-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="white" viewBox="0 0 24 24">
                            <path d="M17 8h-1V6c0-2.8-2.2-5-5-5S6 3.2 6 6v2H5c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM8 6c0-1.7 1.3-3 3-3s3 1.3 3 3v2H8V6zm9 14H5V10h12v10z"/>
                        </svg>
                    </span>

                    <input type="password" @bind="Password" placeholder="Password" />
                </div>

                <!-- Still visible text + cursor, but no onclick -->
                <p class="forgot">
                    <button class="link-button" type="button">Forgot Password</button>
                </p>

                <button class="login-btn" @onclick="SubmitLogin">LOGIN</button>

                <p class="signup-text">
                    Not a member?
                    <button class="link-button signup-link" @onclick="OpenSignup" type="button">Sign up now</button>
                </p>

            </div>
        </div>
    }

    <!-- SIGNUP POPUP -->
    @if (ShowSignup)
    {
        <div class="login-overlay">
            <div class="login-box">

                <!-- Close Button -->
                <button class="close-btn" @onclick="CloseSignup">✕</button>

                <h1 class="login-title">Sign Up</h1>

                @if (ShowSignupError)
                {
                    <div class="error-text">Error. Did you enter a 10 digit phone number that hasn't been used previously?</div>
                }

                @if (ShowSignupSuccess)
                {
                    <div style="color: green;">Account created successfully! Please navigate back to sign in page.</div>
                }

                <!-- Inputs/icons -->
                <div class="input-group">
                    <span class="input-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="white" viewBox="0 0 24 24">
                            <path d="M12 12c2.7 0 5-2.3 5-5s-2.3-5-5-5-5 2.3-5 5 2.3 5 5 5zm0 2c-3.3 0-10 1.7-10 5v3h20v-3c0-3.3-6.7-5-10-5z"/>
                        </svg>
                    </span>
                    <input @bind="SignupName" placeholder="Your Name" />
                </div>

                <div class="input-group">
                    <span class="input-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="white" viewBox="0 0 24 24">
                            <path d="M12 12c2.7 0 5-2.3 5-5s-2.3-5-5-5-5 2.3-5 5 2.3 5 5 5zm0 2c-3.3 0-10 1.7-10 5v3h20v-3c0-3.3-6.7-5-10-5z"/>
                        </svg>
                    </span>
                    <input @bind="SignupPhone" placeholder="Your Phone Number" />
                </div>

                <div class="input-group">
                    <span class="input-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="white" viewBox="0 0 24 24">
                            <path d="M12 12c2.7 0 5-2.3 5-5s-2.3-5-5-5-5 2.3-5 5 2.3 5 5 5zm0 2c-3.3 0-10 1.7-10 5v3h20v-3c0-3.3-6.7-5-10-5z"/>
                        </svg>
                    </span>
                    <input @bind="SignupAddress" placeholder="Your Full Address" />
                </div>

                <div class="input-group">
                    <span class="input-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="white" viewBox="0 0 24 24">
                            <path d="M12 12c2.7 0 5-2.3 5-5s-2.3-5-5-5-5 2.3-5 5 2.3 5 5 5zm0 2c-3.3 0-10 1.7-10 5v3h20v-3c0-3.3-6.7-5-10-5z"/>
                        </svg>
                    </span>
                    <input type="password" @bind="SignupPassword" placeholder="Your Password" />
                </div>

                <p class="signup-text">
                    Already a member?
                    <button class="link-button signup-link" @onclick="OpenLogin" type="button">Sign in now</button>
                </p>
                
                 <button class="login-btn" @onclick="SubmitSignup">SIGN UP</button>

            </div>
        </div>
    }
    @*
    @if (ShowForgot) { <div><div> }
    @if (ShowDeliveryEligibility) { <div><div> }
    *@

    @if (ShowCart)
    {
        <div class="cart-overlay">
            <div class="cart-panel">
                <div class="cart-header">
                    <span class="cart-title">Your Order</span>
                    <button class="cart-close" @onclick="CloseCart">Close</button>
                </div>

                @if (ShowCheckoutError)
                {
                    <div class="error-text">Error. You are not signed in.</div>
                }

                <div class="cart-items">
                    @if (!CartItems.Any())
                    {
                        <p>Your cart is empty.</p>
                    }
                    else
                    {
                        @foreach (var item in CartItems)
                        {
                            <div class="cart-item">
                                <div class="cart-item-info">
                                    <div class="cart-item-name">@item.Name</div>
                                    @if (!string.IsNullOrWhiteSpace(item.Description))
                                    {
                                        <div class="cart-item-desc">@item.Description</div>
                                    }
                                </div>
                                <div class="cart-qty">
                                    <button @onclick="() => DecreaseCartItem(item)">-</button>
                                    <span>@item.Quantity</span>
                                    <button @onclick="() => IncreaseCartItem(item)">+</button>
                                </div>
                            </div>
                        }
                    }
                </div>
                <button class="checkout-btn" @onclick="GoToCheckout">CHECK OUT</button>
            </div>
        </div>
    }

    <!-- Profile slideout - borrows from ShowCart to allow user to logout/ view profile info -->
    @if (ShowProfile)
    {
        <div class="cart-overlay">
            <div class="cart-panel">
                <div class="cart-header">
                    <span class="cart-title">Your Profile</span>
                    <button class="cart-close" @onclick="CloseProfile">Close</button>
                </div>

                <div class="cart-items">
                    @if (CurrentCustomer != null)
                    {
                        <p>Welcome, @(CurrentCustomer?.Name ?? "Guest")!</p>
                        <p>Phone: @(CurrentCustomer?.Phone ?? "")</p>
                        <p>Address: @(CurrentCustomer?.Address ?? "")</p>
                    }
                    else
                    {
                        <p>Welcome, sign in to order.</p>
                    }
                </div>
                @if (CurrentCustomer != null)
                {
                <button class="checkout-btn" @onclick="LogOut">LOG OUT</button>
                }
                else
                {
                <button class="checkout-btn" @onclick="OpenLogin">SIGN IN</button>
                }
            </div>
        </div>
    }

</div>

@code {
    [Inject] NavigationManager Nav { get; set; }

    void GoHome() => Nav.NavigateTo("/");

    // ---------------- NAV INTENT ----------------
    string NextAction = "";

    // ---------------- LOGIN ----------------
    bool ShowLogin = false;
    bool ShowError = false;
    string Phone = "";
    string Password = "";

    void OpenLogin()
    {
        ShowError = false;
        ShowLogin = true;
        ShowProfile = false;
        ShowSignup = false;
        ShowSignupSuccess = false;
        SignupName = "";
        SignupPhone = "";
        SignupAddress = "";
        SignupPassword = "";
    }

    void CloseLogin() => ShowLogin = false;

    // Called by the buttons in the nav / ORDER NOW
    void StartViewMenu() => Nav.NavigateTo("/menu");

    async Task StartDelivery()
    {
        var customer = await CustomerService.GetCustomerAsync();

        if (customer != null)
            {
                Nav.NavigateTo("/builder?mode=delivery");
                return;
            }
    
        NextAction = "delivery";
        ShowLogin = true;
    }

    async Task StartPickup()
    {
        var customer = await CustomerService.GetCustomerAsync();

        if (customer != null)
            {
                Nav.NavigateTo("/builder?mode=pickup");
                return;
            }
    
        NextAction = "pickup";
        ShowLogin = true;
    }

    async Task SubmitLogin()
    {
        if (string.IsNullOrWhiteSpace(Phone) || string.IsNullOrWhiteSpace(Password))
        {
            ShowError = true;
            return;
        }

        bool loginSuccess = await CustomerService.LoginAsync(Phone, Password);

        if (!loginSuccess)
        {
            ShowError = true;
            return;
        }

        ShowError = false;
        ShowLogin = false;

        if (NextAction == "pickup")
        {
            Nav.NavigateTo("/builder?mode=pickup");
        }
        else if (NextAction == "delivery")
        {
            Nav.NavigateTo("/builder?mode=delivery");
        }
        else
        {
            Nav.NavigateTo("/");
        }
    }

    void LogOut()
    {
        Phone = "";
        Password = "";
        CustomerService.Logout();
        CloseProfile();
        Nav.NavigateTo("/");
    }

    // ---------------- PROFILE / CART ----------------
    void GoToProfile() => Nav.NavigateTo("/profile");

    bool ShowCart = false;
    bool ShowProfile = false;
    bool ShowCheckoutError = false;

    class CartItem
    {
        public string Name { get; set; } = "";
        public string Description { get; set; } = "";
        public int Quantity { get; set; }
    }

    List<CartItem> CartItems = new();  // empty by default

    void OpenCart() => ShowCart = true;
    void CloseCart()
    {
        ShowCheckoutError = false;
        ShowCart = false;
    }

    Customer? CurrentCustomer;
    async Task OpenProfile()
    {
        CurrentCustomer = await CustomerService.GetCustomerAsync();
        ShowProfile = true;
    }
    void CloseProfile() => ShowProfile = false;

    void IncreaseCartItem(CartItem item) => item.Quantity++;

    void DecreaseCartItem(CartItem item)
    {
        if (item.Quantity > 1) item.Quantity--;
        else CartItems.Remove(item);
    }

    async Task GoToCheckout()
    {
        var CurrentCustomer = await CustomerService.GetCustomerAsync();

        if (CurrentCustomer != null)
            {
            ShowCheckoutError = false;
            Nav.NavigateTo("/checkout");
            }
        else
        {
            ShowCheckoutError = true;
        }
    }

    // -----------SIGN UP-----------
    bool ShowSignup = false;
    bool ShowSignupError = false;
    bool ShowSignupSuccess = false;
    string SignupName = "";
    string SignupPhone = "";
    string SignupAddress = "";
    string SignupPassword = "";
    void OpenSignup() 
    {
        ShowSignup = true;
        ShowLogin = false;
        StateHasChanged();
    }

    void CloseSignup() 
    {
        ShowSignup = false;
        ShowSignupSuccess = false;
        ShowSignupError = false;
        SignupName = "";
        SignupPhone = "";
        SignupAddress = "";
        SignupPassword = "";
    }

    async Task SubmitSignup()
    {
        bool SignupSuccess = await CustomerService.SignUpAsync(SignupName, SignupPhone, SignupAddress, SignupPassword);

        if (!SignupSuccess)
        {
            ShowSignupError = true;
        }

        else
        {
            ShowSignupSuccess = true;
            ShowSignupError = false;
            SignupName = "";
            SignupPhone = "";
            SignupAddress = "";
            SignupPassword = "";
        }
    }

    // ---------------- EXTRA POPUPS (disabled) ----------------
    @* 
    bool ShowForgot = false;
    bool ShowDeliveryEligibility = false;
    bool IsOutsideDeliveryArea = true;
    bool HasCheckedDeliveryArea = false;
    string DeliveryNotes = "";
    string ForgotPhone = "";
    bool ShowForgotError = false;

    void OpenForgot() { ... }
    void CloseForgot() { ... }
    void BackToLoginFromSignup() { ... }
    void BackToLoginFromForgot() { ... }
    void SubmitSignup() { ... }
    void SendResetLink() { ... }
    void CloseDeliveryEligibility() { ... }
    void CheckDeliveryArea() { ... }
    void GoToPickupFromEligibility() { ... }
    void ContinueDelivery() { ... }
    void BackToLoginFromEligibility() { ... }
    *@
}
